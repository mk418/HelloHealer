# BigWigs packager config. Used by the CurseForge / WowInterface
# release-builder GitHub Action and by `release.sh` runs locally.
#
# Libraries are embedded — committed under Libs/ alongside the rest
# of the source — rather than fetched as externals. WowAce SVN
# externals were attempted first but the canonical LibStub /
# LibHealComm-4.0 hosts are no longer reliably reachable, so
# resolution fails the build. Embedding sidesteps the host
# dependency entirely; library upgrades become explicit commits
# that land in the same git history as everything else.
#
# LibHealComm-4.0 is the standalone CurseForge build (not the
# HealBot Continued fork). On Classic Era 1.15 the HealBot fork's
# UNIT_SPELLCAST_START handler silently bails for Shaman casts —
# no errors, no callbacks fire — and the standalone build does
# not. Swapping forks is the fix; do not regress without verifying
# Shaman heal prediction still works.

package-as: HelloHealer

# Files that should NOT end up in the released zip. The packager
# already excludes hidden files by default, but listing key items
# explicitly avoids surprises.
ignore:
    - .gitignore
    - .pkgmeta
    - .github
    - DESIGN.md
    - README.md
    # Project logo. Kept in the repo for use as the CurseForge project
    # icon and any future docs/marketing surface, but not referenced
    # anywhere in the addon itself — WoW can't load PNG textures at
    # runtime. Excluded from the released zip so users don't pull
    # down a 1.6 MB file the addon never reads.
    - HelloHealer.png

# Generate a -nolib variant of the zip so users who already have
# LibStub/LibHealComm via another addon can grab a smaller download
# without redundant lib copies.
enable-nolib-creation: yes

# No `manual-changelog` block: the packager auto-generates the
# changelog from git commit messages between tags.
